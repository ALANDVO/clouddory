# Database
DATABASE_URL="mysql://user:password@localhost:3306/clouddory"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Admin emails (comma-separated)
ADMIN_EMAILS="admin@yourcompany.com"

# AWS (for CloudDory's own account to assume customer roles)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_DEFAULT_REGION="us-east-1"
NEXT_PUBLIC_AWS_ACCOUNT_ID=""
NEXT_PUBLIC_CF_TEMPLATE_URL=""

# AI API Keys (optional — can also be configured via Settings > AI Config)
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
